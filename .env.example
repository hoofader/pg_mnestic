# Copy to .env and fill in for real memory quality. Without these, quickstart.sh runs the
# stack with mock providers (deterministic, non-semantic embeddings), which is fine for trying
# the API but not for judging recall.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database passwords. quickstart.sh generates these into .env on first run if absent, so the
# one-command flow needs no editing. POSTGRES_PASSWORD is the superuser (migrations + role
# provisioning); MNESTIC_APP_PASSWORD is the non-superuser mnestic_app role the server and worker
# actually serve as, so RLS is enforced. Set both to long random values for any real deploy.
POSTGRES_PASSWORD=
MNESTIC_APP_PASSWORD=
